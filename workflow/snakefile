rule colorize_labeled:
    input:
        labeled = "{stem}labels_map.tiff",
        init = "init-colorize.txt"
    output:
        colorized = "{stem}labels_map.colorized.tiff"
    shell:
        "{config[COLORIZE]} {input.labeled} {output.colorized}"
