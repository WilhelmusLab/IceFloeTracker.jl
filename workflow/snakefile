        "--datetime {wildcards.year}-01-01"


rule load_landmask:
    output:
        "{stem}landmask.tiff"
    input:
        "{stem}landmask_raw.tiff"
    shell:
        """
        {config[IFT]} -e 'using IceFloeTracker, Images; 
            load("{input}") |> to_landmask .|> Bool .|> Gray |> save("{output}")
        '
        """

