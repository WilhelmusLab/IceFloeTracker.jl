rule segment:
    output:
        labels_map = "{dir}/{pipeline}/labels_map.tiff",
        cloud_mask = "{dir}/{pipeline}/cloud_mask.tiff",
        ice_mask = "{dir}/{pipeline}/ice_mask.tiff",
        config = "{dir}/{pipeline}/config.txt",
        segment_mean_truecolor = "{dir}/{pipeline}/segment_mean_truecolor.tiff",
        segment_mean_falsecolor = "{dir}/{pipeline}/segment_mean_falsecolor.tiff",
    input:
        truecolor = "{dir}/truecolor.tiff",
        falsecolor = "{dir}/falsecolor.tiff",
        landmask = "{dir}/landmask.tiff",
        coastal_buffer_mask = "{dir}/coastal_buffer_mask.tiff",
    shell:
        """
        {config[IFT]} -e 'using IceFloeTracker, Images;
        segmentation_algorithm = {wildcards.pipeline}.Segment();
        open("{output.config}", "w") do io
            Base.println(io, "IceFloeTracker.jl $(pkgversion(IceFloeTracker)) \n")
            Base.dump(io, segmentation_algorithm)
        end;
        segmentation_algorithm(
            load("{input.truecolor}"),
            load("{input.falsecolor}"),
            load("{input.landmask}") |> binarize_mask,
            load("{input.coastal_buffer_mask}") |> binarize_mask;
            intermediate_results_callback=call_kwargs(;
                labels_map=l -> l .|> UInt16 |> save("{output.labels_map}"),
                cloud_mask=save("{output.cloud_mask}"),
                ice_mask=save("{output.ice_mask}"),
                segment_mean_truecolor=save("{output.segment_mean_truecolor}"),
                segment_mean_falsecolor=save("{output.segment_mean_falsecolor}"),
            ),
        )'
        """
        

rule segment_buckley:
    output:
        labels_map = "{dir}/buckley/labels_map.tiff",
        props = "{dir}/buckley/props.csv",
        truecolor_cloudmasked = "{dir}/buckley/cloud_mask_on_rgb.tif",
        truecolor_land_cloudmasked = "{dir}/buckley/land_cloud_mask_on_rgb.tif",
    input:
        truecolor = "{dir}/truecolor.tiff",
        cloud_map = "{dir}/cloud.tiff",
        landmask = "{dir}/landmask.tiff",
    shell:
        """
        mkdir -p {wildcards.dir}/buckley;

        {config[FSDPROC]} process \
            {input.truecolor} \
            {input.cloud_map} \
            {input.landmask} \
            {wildcards.dir}/buckley/

        ln {wildcards.dir}/buckley/final.tif {output.labels_map}
        """

ruleorder: segment_buckley > segment

# ============================================================================
# TRACKING RULES
# ============================================================================


rule tracking:
    output:
        tracked = "{region}.{scale}m.{start}.{end}.{pipeline}.tracked.csv",
        config = "{region}.{scale}m.{start}.{end}.{pipeline}.tracked.config.txt"
    input:
        labels_maps = lambda wc: expand("{region}.{scale}m.{date}.{satellite}/{pipeline}/labels_map.tiff",
                          satellite=config["SATELLITES"],
                          date=daterange(date.fromisoformat(wc.start),
                                         date.fromisoformat(wc.end)),
                          **wc
                          ),

        overpasses = lambda wc: expand("{region}.{scale}m.{date}.{satellite}/overpass.txt",
                          satellite=config["SATELLITES"],
                          date=daterange(date.fromisoformat(wc.start),
                                         date.fromisoformat(wc.end)),
                          **wc
                          )
    shell:
        """
        {config[IFT]} -e 'using IceFloeTracker, Images, TimeZones, CSVFiles, DataFrames;
        # Load input data
        overpasses = "{input.overpasses}" |> split .|> (n-> read(n, String)) .|> chomp .|> ZonedDateTime .|> DateTime;
        labels_maps = "{input.labels_maps}" |> split .|> load .|> x -> reinterpret(Int16, x);
        imgs = labels_maps .|> x -> Int16.(x) .|> .>(0) .|> Gray;  # for tracking, we only need the shape of the segments, not the actual labels, so convert to binary masks
        segmented_imgs = map((tc, lm) -> SegmentedImage(tc, Int64.(lm)), imgs, labels_maps);

        # Sort into chronological order
        order = sortperm(overpasses);
        overpasses = overpasses[order];
        segmented_imgs = segmented_imgs[order];
        tracker = {wildcards.pipeline}.Track();
        open("{output.config}", "w") do io
            Base.println(io, "IceFloeTracker.jl $(pkgversion(IceFloeTracker)) \n")
            Base.dump(io, tracker)
        end;
        tracked = tracker(segmented_imgs, overpasses);
        select!(tracked, Not(:mask, :psi));
        save("{output.tracked}", tracked);
        '
        """
