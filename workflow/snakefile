rule load_truecolor:
    output:
        "{region}.{scale}m.{date}.{satellite}/truecolor.tiff"
    params:
        bbox = lambda wc: get_region_target_bbox(wc.region),
        crs = lambda wc: get_region_data(wc.region)["target_crs"]
    shell:
        "{config[LOADER]} {output} --kind truecolor "
        "--crs {params.crs} --bbox {params.bbox} --scale {wildcards.scale} "
        "--datetime {wildcards.date} --satellite {wildcards.satellite}"

rule load_falsecolor:
    output:
        "{region}.{scale}m.{date}.{satellite}/falsecolor.tiff"
    params:
        bbox = lambda wc: get_region_target_bbox(wc.region),
        crs = lambda wc: get_region_data(wc.region)["target_crs"]
    shell:
        "{config[LOADER]} {output} --kind bands721 "
        "--crs {params.crs} --bbox {params.bbox} --scale {wildcards.scale} "
        "--datetime {wildcards.date} --satellite {wildcards.satellite}"

rule load_cloud:
    output:
        "{region}.{scale}m.{date}.{satellite}/cloud.tiff"
    params:
        bbox = lambda wc: get_region_target_bbox(wc.region),
        crs = lambda wc: get_region_data(wc.region)["target_crs"]
    shell:
        "{config[LOADER]} {output} --kind cloud "
        "--crs {params.crs} --bbox {params.bbox} --scale {wildcards.scale} "
        "--datetime {wildcards.date} --satellite {wildcards.satellite}"


rule load_raw_landmask:
    output:
        "{region}/{scale}m.{year}.landmask_raw.tiff"
    params:
        bbox = lambda wc: get_region_target_bbox(wc.region),
        crs = lambda wc: get_region_data(wc.region)["target_crs"]
    shell:
        "{config[LOADER]} {output} --kind landmask "
        "--crs {params.crs} --bbox {params.bbox} --scale {wildcards.scale} "
        "--datetime {wildcards.year}-01-01"


rule load_landmask:
    output:
        "{stem}landmask.tiff"
    input:
        "{stem}landmask_raw.tiff"
    shell:
        """
        {config[IFT]} -e 'using IceFloeTracker, Images; 
            load("{input}") |> binarize_mask .|> Bool .|> Gray |> save("{output}")
        '
        """

rule load_coastal_buffer_mask:
