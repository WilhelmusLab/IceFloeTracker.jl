import os
from datetime import timedelta, date
import calendar
import pyproj
import pandas as pd

configfile: "workflow/config.yaml"
workdir: "workflow/results"
# The profile in workflow/profiles/default/config.yaml sets default values for this workflow.

regions = pd.read_csv(config["REGION_CSV"]).set_index("region")
cases = pd.read_csv(config["CASE_CSV"])

def daterange(start_date, end_date):
    """Generates dates from start_date to end_date (inclusive)."""
    date = start_date
    while date <= end_date:
        yield date
        date += timedelta(days=1)


def last_day_of_month(year, month):
    """Returns the last day of a given month and year."""
    _, last_day = calendar.monthrange(year, month)
    date_ = date(year, month, last_day)
    return date_


def get_bbox(center_crs, centroid, target_crs, target_width_height):
    """Given a centroid coordinate, its CRS, and a target width and height in meters, 
    returns a bounding box in the target CRS."""
    transformer = pyproj.Transformer.from_crs(
        center_crs, target_crs, always_xy=True)
    centroid = transformer.transform(centroid[1], centroid[0])
    center_round = list(map(round, centroid))
    half_width = target_width_height[0] / 2
    half_height = target_width_height[1] / 2
    min_x = center_round[0] - half_width
    max_x = center_round[0] + half_width
    min_y = center_round[1] - half_height
    max_y = center_round[1] + half_height
    return f"{min_x},{min_y},{max_x},{max_y}"


def get_region_data(region):
    data = regions.loc[region].to_dict()
    return data

def get_region_centroid(region):
    data = get_region_data(region)
    crs, lat, lon = data["center_crs"], float(data["center_lat"]), float(data["center_lon"])
    return crs, (lat, lon)

def get_region_target_extent(region):
    data = get_region_data(region)
    crs, width, height = data["target_crs"], float(data["target_width"]), float(data["target_height"])
    return crs, (width, height)

def get_region_target_bbox(region):
    data = get_region_data(region)
    centroid = get_region_centroid(region)
    extent = get_region_target_extent(region)
    bbox = get_bbox(*centroid, *extent)
    return bbox


