envvars:
    "SPACEUSER",
    "SPACEPSWD"

rule get_region_overpass_times:
    output:
        "{region}/{year}.overpasses.csv"
    wildcard_constraints:
        year = "[0-9]{4}"
    params:
        SPACEUSER = os.environ["SPACEUSER"],
        SPACEPSWD = os.environ["SPACEPSWD"],
        start = "{year}-01-01",
        end = "{year}-12-31",
        center_lat = lambda wc: get_region_data(wc.region)["center_lat"],
        center_lon = lambda wc: get_region_data(wc.region)["center_lon"]
    shell:
        "{config[PASS_TIME]} --csvoutpath {output} "
        "--startdate {params.start} --enddate {params.end} "
        "--centroid-lat {params.center_lat} --centroid-lon {params.center_lon} "
        "--SPACEUSER {params.SPACEUSER} --SPACEPSWD {params.SPACEPSWD}"

rule get_region_month_overpass_times:
    output:
        "{region}/{year}.{month}.overpasses.csv"
    params:
        SPACEUSER = os.environ["SPACEUSER"],
        SPACEPSWD = os.environ["SPACEPSWD"],
        start = "{year}-{month}-01",
        end = lambda wc: last_day_of_month(
            int(wc.year), int(wc.month)).strftime("%Y-%m-%d"),
        center_lat = lambda wc: get_region_data(wc.region)["center_lat"],
        center_lon = lambda wc: get_region_data(wc.region)["center_lon"]
    shell:
        "{config[PASS_TIME]} --csvoutpath {output} "
        "--startdate {params.start} --enddate {params.end} "
        "--centroid-lat {params.center_lat} --centroid-lon {params.center_lon} "
        "--SPACEUSER {params.SPACEUSER} --SPACEPSWD {params.SPACEPSWD}"


rule get_single_overpass_time:
    output:
        "{region}.{scale}m.{year}-{month}-{day}.{satellite}/overpass.txt"
    input:
        "{region}/{year}.{month}.overpasses.csv"
    wildcard_constraints:
        year = "[0-9]{4}",
        month = "[0-9]{2}",
        day = "[0-9]{2}"
    params:
        date = lambda wc: f"{wc.year}-{wc.month}-{wc.day}"
    run:
        import csv
        overpass_time = None
        with open(input[0]) as f:
            csvfile = csv.reader(f)
            for row in csvfile:
                if row and row[0] == params.date and row[1] == wildcards.satellite:
                    overpass_time = row[2]
                    break
        with open(output[0], "w") as f:
            f.write(overpass_time + "\n")

rule get_case_overpass_time:
    output:
        "{region}.{scale}m.{year}-{month}-{day}.{satellite}/overpass.txt"
    input:
        "{region}.{scale}m.{year}-{month}-{day}.{satellite}/overpass.txt"
    shell:
        "cp {input} {output}"

